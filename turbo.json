{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "inputs": ["src/**", "rslib.config.ts", "package.json"],
      "outputs": ["dist/**"],
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "dependsOn": ["^build"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "src/**", "test/**", "vitest.config.ts"],
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate:schema": {},
    "//#lint": {
      "dependsOn": ["^typecheck"]
    },
    "//#format": {
      "dependsOn": ["^typecheck"]
    },
    "//#docs:generate": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
