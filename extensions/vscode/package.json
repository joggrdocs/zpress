{
  "name": "zpress-vscode",
  "private": true,
  "displayName": "zpress",
  "version": "0.2.0",
  "description": "Run zpress dev server and preview documentation from VS Code",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "extensions/vscode"
  },
  "publisher": "joggr",
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-git-tag-version",
    "publish": "vsce publish --no-git-tag-version"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "typescript": "catalog:"
  },
  "contributes": {
    "commands": [
      {
        "command": "zpress.start",
        "title": "zpress: Start Dev Server"
      },
      {
        "command": "zpress.stop",
        "title": "zpress: Stop Dev Server"
      },
      {
        "command": "zpress.toggle",
        "title": "zpress: Toggle Dev Server",
        "icon": "$(debug-start)"
      },
      {
        "command": "zpress.preview",
        "title": "zpress: Preview Page",
        "icon": "$(globe)"
      },
      {
        "command": "zpress.openPage",
        "title": "zpress: Open Page"
      },
      {
        "command": "zpress.restart",
        "title": "zpress: Restart Dev Server"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "zpress.preview",
          "when": "resourceLangId == markdown && zpress:isTrackedFile && zpress:serverReady",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "zpress.toggle",
          "when": "view =~ /^zpress\\.(loading|section)/",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zpress",
          "title": "zpress",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "zpress.loading",
        "contents": "$(sync~spin) Starting zpress dev server...",
        "when": "zpress:serverStarting"
      },
      {
        "view": "zpress.loading",
        "contents": "zpress dev server is stopped.\n[Start Server](command:zpress.start)",
        "when": "zpress:serverStopped"
      }
    ],
    "views": {
      "zpress": [
        {
          "id": "zpress.loading",
          "name": "zpress",
          "when": "zpress:isProject && !zpress:serverReady"
        },
        {
          "id": "zpress.section.0",
          "name": "Section",
          "when": "zpress:section.0 && zpress:serverReady",
          "visibility": "visible"
        },
        {
          "id": "zpress.section.1",
          "name": "Section",
          "when": "zpress:section.1 && zpress:serverReady",
          "visibility": "collapsed"
        },
        {
          "id": "zpress.section.2",
          "name": "Section",
          "when": "zpress:section.2 && zpress:serverReady",
          "visibility": "collapsed"
        },
        {
          "id": "zpress.section.3",
          "name": "Section",
          "when": "zpress:section.3 && zpress:serverReady",
          "visibility": "collapsed"
        },
        {
          "id": "zpress.section.4",
          "name": "Section",
          "when": "zpress:section.4 && zpress:serverReady",
          "visibility": "collapsed"
        },
        {
          "id": "zpress.section.5",
          "name": "Section",
          "when": "zpress:section.5 && zpress:serverReady",
          "visibility": "collapsed"
        },
        {
          "id": "zpress.section.6",
          "name": "Section",
          "when": "zpress:section.6 && zpress:serverReady",
          "visibility": "collapsed"
        },
        {
          "id": "zpress.section.7",
          "name": "Section",
          "when": "zpress:section.7 && zpress:serverReady",
          "visibility": "collapsed"
        }
      ]
    }
  },
  "activationEvents": [
    "workspaceContains:zpress.config.js",
    "workspaceContains:zpress.config.json",
    "workspaceContains:zpress.config.mjs",
    "workspaceContains:zpress.config.mts",
    "workspaceContains:zpress.config.ts"
  ],
  "extensionKind": [
    "workspace"
  ],
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.110.0"
  }
}
