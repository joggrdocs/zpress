{
  "name": "zpress-vscode",
  "displayName": "zpress",
  "description": "Run zpress dev server and preview documentation from VS Code",
  "version": "0.1.0",
  "private": true,
  "publisher": "joggr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "extensions/vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:zpress.config.ts",
    "workspaceContains:zpress.config.js",
    "workspaceContains:zpress.config.json"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "contributes": {
    "commands": [
      {
        "command": "zpress.start",
        "title": "zpress: Start Dev Server"
      },
      {
        "command": "zpress.stop",
        "title": "zpress: Stop Dev Server"
      },
      {
        "command": "zpress.toggle",
        "title": "zpress: Toggle Dev Server"
      },
      {
        "command": "zpress.openInBrowser",
        "title": "zpress: View in Browser",
        "icon": "$(globe)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "zpress.openInBrowser",
          "when": "resourceLangId == markdown && zpress:isTrackedFile",
          "group": "navigation"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.0",
    "typescript": "catalog:"
  }
}
