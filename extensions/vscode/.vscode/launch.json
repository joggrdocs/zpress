{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Kitchen Sink)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/../../examples/kitchen-sink",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: watch"
    },
    {
      "name": "Run Extension (Simple)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/../../examples/simple",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: watch"
    },
    {
      "name": "Run Extension (No Pre-Launch)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/../../examples/kitchen-sink",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    }
  ]
}
