{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"]
  },
  "exclude": ["node_modules"]
}
