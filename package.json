{
  "name": "zpress-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "clean": "lauf run clean",
    "format": "oxfmt",
    "format:fix": "oxfmt --write",
    "lint": "oxlint --ignore-pattern node_modules",
    "lint:fix": "oxlint --fix --ignore-pattern node_modules",
    "test": "turbo run test",
    "check": "turbo run typecheck && pnpm lint && pnpm format",
    "changeset": "changeset",
    "version": "changeset version && oxfmt --write",
    "release": "pnpm build && changeset publish",
    "docs:build": "node packages/zpress/dist/cli.mjs build",
    "docs:serve": "node packages/zpress/dist/cli.mjs serve",
    "dev": "pnpm build && lauf run docs && turbo run dev",
    "dev:playground": "pnpm build && pnpm --filter @zpress/ui dev"
  },
  "dependencies": {
    "@zpress/kit": "workspace:*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@iconify-json/catppuccin": "^1.2.17",
    "@iconify-json/devicon": "^1.2.60",
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/material-icon-theme": "^1.2.55",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/pixelarticons": "^1.2.4",
    "@iconify-json/simple-icons": "^1.2.73",
    "@iconify-json/skill-icons": "^1.2.4",
    "@iconify-json/vscode-icons": "^1.2.45",
    "@microsoft/api-extractor": "^7.57.7",
    "@types/node": "^25.5.0",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-security": "^4.0.0",
    "laufen": "^1.1.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.17",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
