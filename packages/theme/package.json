{
  "name": "@zpress/theme",
  "version": "0.1.0",
  "description": "Theme types and definitions for zpress",
  "keywords": [
    "theme",
    "types",
    "zpress"
  ],
  "homepage": "https://github.com/joggrdocs/zpress/tree/main/packages/theme#readme",
  "bugs": "https://github.com/joggrdocs/zpress/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "packages/theme"
  },
  "files": [
    "dist"
  ],
  "type": "module",
