{
  "name": "@zpress/core",
  "version": "0.2.0",
  "description": "Config loading, sync engine, and asset utilities for zpress",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
