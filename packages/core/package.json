    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch --no-clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "c12": "4.0.0-beta.3",
    "es-toolkit": "^1.45.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@rslib/core": "^0.20.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
