                        {
                          "type": "string",
                          "enum": [
                            "alpha",
                            "filename"
                          ]
                        }
                      ]
                    },
                    "recursive": {
                      "type": "boolean"
                    },
                    "indexFile": {
                      "type": "string"
                    },
                    "icon": {
                      "type": "string"
                    },
                    "iconColor": {
                      "type": "string"
                    },
                    "card": {
                      "type": "object",
                      "properties": {
                        "icon": {
                          "type": "string"
                        },
                        "iconColor": {
                          "type": "string"
                        },
                        "scope": {
                          "type": "string"
                        },
                        "description": {
                          "type": "string"
                        },
                        "tags": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "badge": {
                          "type": "object",
                          "properties": {
                            "src": {
                              "type": "string"
