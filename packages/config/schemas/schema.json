              "description": {
                "type": "string"
              },
              "icon": {
                "type": "string"
              },
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/ZpressConfig/properties/apps/items"
                },
                "minItems": 1
              },
              "link": {
                "type": "string"
              }
            },
            "required": [
              "title",
              "description",
              "icon",
              "items"
            ],
            "additionalProperties": false
          }
        },
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "$ref": "#/definitions/ZpressConfig/properties/apps/items/properties/title"
              },
              "description": {
                "type": "string"
              },
              "link": {
                "type": "string"
              },
              "icon": {
                "type": "string"
              }
            },
            "required": [
              "title",
              "description"
            ],
            "additionalProperties": false
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
