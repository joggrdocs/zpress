            },
            "colors": {
              "type": "object",
              "properties": {
                "brand": {
                  "type": "string"
                },
                "brandLight": {
                  "type": "string"
                },
                "brandDark": {
                  "type": "string"
                },
                "brandSoft": {
                  "type": "string"
                },
                "bg": {
                  "type": "string"
                },
                "bgAlt": {
                  "type": "string"
                },
                "bgElv": {
                  "type": "string"
                },
                "bgSoft": {
                  "type": "string"
                },
                "text1": {
                  "type": "string"
                },
                "text2": {
                  "type": "string"
                },
                "text3": {
                  "type": "string"
                },
                "divider": {
                  "type": "string"
                },
                "border": {
                  "type": "string"
                },
