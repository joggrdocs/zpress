                          "color": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "color"
                        ],
                        "additionalProperties": false
                      }
                    ]
                  }
                },
                "required": [
                  "text",
                  "link"
                ],
                "additionalProperties": false
              }
            },
            "below": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ZpressConfig/properties/sidebar/properties/above/items"
