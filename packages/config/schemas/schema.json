        "icon": {
          "type": "string"
        },
        "tagline": {
          "type": "string"
        },
        "apps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "from": {
                        "type": "string",
                        "enum": [
                          "auto",
                          "filename",
                          "heading",
                          "frontmatter"
                        ]
                      }
                    },
                    "required": [
                      "from"
                    ],
                    "additionalProperties": false
                  }
                ]
              },
              "icon": {
                "type": "string"
              },
              "iconColor": {
                "type": "string"
              },
              "description": {
