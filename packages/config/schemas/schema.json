                            "alt": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "src",
                            "alt"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "additionalProperties": false
                    },
                    "isolated": {
                      "type": "boolean"
                    },
                    "titleFrom": {
                      "type": "string",
                      "enum": [
                        "filename",
                        "heading",
                        "frontmatter",
                        "auto"
                      ]
                    }
                  },
                  "required": [
