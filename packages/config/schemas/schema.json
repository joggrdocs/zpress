                "type": "object",
                "properties": {
                  "from": {
                    "type": "string"
                  },
                  "title": {
                    "$ref": "#/definitions/ZpressConfig/properties/apps/items/properties/title"
                  },
                  "sort": {
                    "anyOf": [
                      {
                        "type": "string",
                        "enum": [
                          "alpha",
                          "filename"
                        ]
                      }
                    ]
                  },
                  "exclude": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
