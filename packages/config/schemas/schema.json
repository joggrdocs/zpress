        "nav": {
          "anyOf": [
            {
              "type": "string",
              "const": "auto"
            },
            {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string"
                  },
                  "link": {
                    "type": "string"
                  },
                  "items": {
                    "type": "array",
                    "items": {
                      "$ref": "#/definitions/ZpressConfig/properties/nav/anyOf/1/items"
                    }
                  },
                  "activeMatch": {
                    "type": "string"
                  }
                },
                "required": [
                  "text"
                ],
                "additionalProperties": false
              }
            }
          ]
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "sections"
      ],
      "additionalProperties": false
    }
  }
}