              "text": {
                "type": "string"
              },
              "link": {
                "type": "string"
              }
            },
            "required": [
              "theme",
              "text",
              "link"
            ],
            "additionalProperties": false
          }
        },
        "sidebar": {
          "type": "object",
          "properties": {
            "above": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string"
                  },
                  "link": {
                    "type": "string"
                  },
                  "icon": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
