{
  "name": "zpress",
  "version": "0.1.0",
  "description": "Documentation framework powered by Rspress with a config-driven information architecture",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "packages/zpress"
  },
  "bin": {
    "zpress": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./dist/config.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch --no-clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zpress/cli": "workspace:*",
    "@zpress/core": "workspace:*",
    "@zpress/ui": "workspace:*"
  },
  "devDependencies": {
    "@rslib/core": "^0.20.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
