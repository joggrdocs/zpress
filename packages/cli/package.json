{
  "name": "@zpress/cli",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "packages/cli"
  },
  "bin": {
    "zpress": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "dev": "node ./dist/index.mjs dev --cwd ../..",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kidd-cli/core": "^0.2.0",
    "@rspress/core": "2.0.5",
    "@zpress/core": "workspace:*",
    "@zpress/ui": "workspace:*",
    "chokidar": "^5.0.0",
    "es-toolkit": "^1.45.1",
    "ts-pattern": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rslib/core": "^0.20.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
