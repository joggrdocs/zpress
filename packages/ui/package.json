{
  "name": "@zpress/ui",
  "version": "0.2.1",
  "description": "Rspress plugin, theme components, and styles for zpress",
  "keywords": [
    "react",
    "rspress",
    "theme",
    "ui",
    "zpress"
  ],
  "homepage": "https://github.com/joggrdocs/zpress/tree/main/packages/ui#readme",
  "bugs": "https://github.com/joggrdocs/zpress/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joggrdocs/zpress.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist",
    "src/theme"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./theme": {
      "types": "./src/theme/index.tsx",
      "import": "./src/theme/index.tsx"
    },
    "./icons": {
      "types": "./src/theme/icons/index.ts",
      "import": "./src/theme/icons/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch --no-clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@iconify-json/catppuccin": "^1.2.17",
    "@iconify-json/devicon": "^1.2.59",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/pixelarticons": "^1.2.4",
    "@iconify-json/simple-icons": "^1.2.73",
    "@iconify-json/skill-icons": "^1.2.4",
    "@iconify/react": "^6.0.2",
    "@zpress/core": "workspace:*",
    "ts-pattern": "catalog:"
  },
  "devDependencies": {
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/material-icon-theme": "^1.2.55",
    "@iconify-json/vscode-icons": "^1.2.45",
    "@rslib/core": "catalog:",
    "@rspress/core": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "geist": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@rspress/core": "catalog:",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
