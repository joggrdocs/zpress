{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Kitchen Sink)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/examples/kitchen-sink",
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/vscode"
      ],
      "outFiles": ["${workspaceFolder}/extensions/vscode/dist/**/*.js"],
      "preLaunchTask": "vscode: watch"
    },
    {
      "name": "Run Extension (Simple)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/examples/simple",
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/vscode"
      ],
      "outFiles": ["${workspaceFolder}/extensions/vscode/dist/**/*.js"],
      "preLaunchTask": "vscode: watch"
    },
    {
      "name": "Run Extension (No Pre-Launch)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}/examples/kitchen-sink",
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/vscode"
      ],
      "outFiles": ["${workspaceFolder}/extensions/vscode/dist/**/*.js"]
    }
  ]
}
